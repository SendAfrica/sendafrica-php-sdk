{
    "name": "sendafrica/sendafrica",
    "description": "Official PHP client for the SendAfrica SMS Infrastructure-as-a-Service API.",
    "type": "library",
    "license": "MIT",
    "keywords": ["sms", "africa", "sendafrica", "messaging", "otp", "sms-api"],
    "authors": [
        {
            "name": "SendAfrica",
            "email": "hello@sendafrica.online",
            "url": "https://sendafrica.online"
        }
    ],
    "require": {
        "php": ">=7.4",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "SendAfrica\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SendAfrica\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/sendafrica"
    ],
    "config": {
        "sort-packages": true,
        "bin-dir": "vendor/bin"
    },
    "minimum-stability": "stable"
}
